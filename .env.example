## Bitrix24 connectivity
# Inbound webhook URL — preferred, used by /api/* endpoints, migration and
# cron. Format: https://<portal>/rest/<userId>/<token>/
BITRIX_WEBHOOK_URL=

# OAuth placeholders (server token storage NOT yet implemented in this repo,
# kept for future use and clarity).
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
BITRIX_PORTAL=b24-5syfa7.bitrix24.ru
APP_BASE_URL=https://calendar-interpro-app.onrender.com

## Smart-process userfield entity
# Bitrix admin shows the smart-process "Выставки" with userfield entity
# CRM_8 (the numeric handle "8", NOT the entityTypeId 1050). Override only
# if your portal uses CRM_1050 directly.
BITRIX_UF_ENTITY_ID=CRM_8

## Cron / parsing rate limit
PARSE_RATE_LIMIT_MS=1000
OWNER_USER_ID=1
# personal | chat
CRON_REPORT_CHANNEL=personal
# Required when CRON_REPORT_CHANNEL=chat (e.g. chat123 or sg5)
CRON_REPORT_CHAT_ID=

## Client (Vite) build-time settings
# Comma-separated whitelist of Bitrix deal STAGE_ID values that qualify a deal
# for the calendar's "График застройки" tab. Tail-matching is applied, so the
# default below also matches "C1:8", "C1:9", "C2:WON", etc. Default when unset:
#   8,9,WON
# Set this if your portal uses different pinned stage IDs.
VITE_BUILD_SCHEDULE_STAGE_IDS=8,9,WON

# Origin of the Bitrix portal (used to compose deal URLs for the build-schedule
# bars: <portal>/crm/deal/details/<id>/). When unset, the bar still opens via
# the in-app event-details page.
VITE_BITRIX_PORTAL_URL=

## Admin job token (REQUIRED to enable the /api/admin/fill-source-urls UI)
# A random, long secret (e.g. `openssl rand -hex 32`) that authorises the
# protected admin endpoint. Without this value set, the endpoint returns 503
# and the in-app UI button is unusable. Must be set manually in the Render
# dashboard → Service → Environment → Add Environment Variable. Never commit
# the real value to git.
ADMIN_JOB_TOKEN=
